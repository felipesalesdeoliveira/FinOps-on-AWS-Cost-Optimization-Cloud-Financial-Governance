aws_region   = "us-east-1"
project_name = "finops-aws"
environment  = "dev"
owner        = "platform-team"
application  = "finops-governance"
cost_center  = "CC-1001"

email_subscriptions = ["finops@example.com"]
monthly_budget_usd  = "300"

budget_alert_thresholds = [50, 80, 100]
enable_compute_optimizer = true
required_tags = ["Environment", "Owner", "Application", "CostCenter"]

simulate_spot_ondemand = false
simulation_instance_type = "t3.micro"

auto_stop_schedule_expression     = "cron(0 23 ? * MON-FRI *)"
untagged_scan_schedule_expression = "cron(0 12 * * ? *)"
weekly_report_schedule_expression = "cron(0 13 ? * MON *)"
